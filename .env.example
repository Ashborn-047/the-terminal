# SpacetimeDB Configuration
# Required for live backend connections
VITE_SPACETIME_URL=ws://localhost:3000
VITE_SPACETIME_DB_NAME=linux_terminal

# Mocking
# Set to 'true' to run E2E tests without needing a Spacetime instance
VITE_MOCK_SPACETIME=false

# Monitoring
# Set endpoints if streaming metrics
# VITE_PROMETHEUS_ENDPOINT=http://localhost:9090
